# Local development services. Compose injects its internal hostnames automatically.
POSTGRES_URL=postgresql+asyncpg://collector:replace-with-a-random-hex-value@localhost:5432/collector
QDRANT_URL=http://localhost:6333
POSTGRES_DB=collector
POSTGRES_USER=collector
POSTGRES_PASSWORD=replace-with-a-random-hex-value
# Optional Compose overrides for remote infrastructure:
# DOCKER_POSTGRES_URL=postgresql+asyncpg://collector:replace-with-a-random-hex-value@postgres:5432/collector
# DOCKER_QDRANT_URL=http://qdrant:6333
INTERNAL_API_URL=http://backend:8000
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Optional prebuilt images. Set these to your GHCR package URLs and run with --no-build.
# BACKEND_IMAGE=ghcr.io/OWNER/REPOSITORY/backend:latest
# FRONTEND_IMAGE=ghcr.io/OWNER/REPOSITORY/frontend:latest
# Expose port 8000 only when MCP or direct API access is required through a firewall/proxy.
BACKEND_BIND_ADDRESS=127.0.0.1
FRONTEND_BIND_ADDRESS=0.0.0.0

# Protects the REST API and web dashboard. Recommended for any network deployment.
APP_API_KEY=

# OpenAI-compatible chat/completions API
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini

# Embeddings: openai or ollama
EMBEDDING_PROVIDER=openai
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Collection
AUTO_COLLECTION_ENABLED=true
COLLECTOR_INTERVAL=60
CLASSIFICATION_PROMPT=Classify this AI project accurately and return JSON.
SOURCE_FILTERING_PROMPT=Keep useful, substantive AI projects and demos.
GITHUB_TOKEN=

# Optional bearer token for the remote MCP endpoint. Leave blank for local use.
MCP_API_KEY=
