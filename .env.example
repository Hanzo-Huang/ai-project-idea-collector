# App services. Compose injects its internal hostnames automatically.
POSTGRES_DB=collector
POSTGRES_USER=collector
POSTGRES_PASSWORD=replace-with-a-random-hex-value

# Bind services to localhost for reverse-proxy deployments.
BACKEND_BIND_ADDRESS=127.0.0.1
FRONTEND_BIND_ADDRESS=127.0.0.1

# Optional: add your public API origin if exposing the backend on another domain.
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# Protects the REST API and web dashboard. Recommended for any network deployment.
APP_API_KEY=

# OpenAI-compatible chat/completions API
LLM_BASE_URL=https://api.openai.com/v1
LLM_API_KEY=
CLASSIFICATION_MODEL=gpt-4o-mini
CHAT_MODEL=gpt-4o-mini

# Embeddings: openai or ollama
EMBEDDING_PROVIDER=openai
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Collection
AUTO_COLLECTION_ENABLED=true
COLLECTOR_INTERVAL=60
CLASSIFICATION_PROMPT=Classify this item for RK3576/RK3588 AI project discovery. Prefer edge AI, NPU deployability, computer vision, audio, robotics, agents, multimodal demos, and major AI events that can inspire Rockchip board content.
SOURCE_FILTERING_PROMPT=Keep useful AI projects, demos, model releases, tutorials, hardware deployments, and major AI events that could inspire RK3576/RK3588 content.
GITHUB_TOKEN=

# Optional bearer token for the remote MCP endpoint. Leave blank for local use.
MCP_API_KEY=
